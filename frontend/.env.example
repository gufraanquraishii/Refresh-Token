# Copy to .env.local and fill in AUTH_SECRET (generate: openssl rand -base64 32)
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_API_URL=http://localhost:4000
# Browser → Express (Dashboard /user/me). Defaults to http://localhost:4000 if unset.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Verbose [next-auth] logs in the Node server terminal (set false to disable)
# AUTH_DEBUG=false
# Log every "access token still valid" line (very noisy; default off)
# AUTH_DEBUG_VERBOSE=true
